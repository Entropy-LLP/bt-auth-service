PORT=3001
NODE_ENV=development

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

REDIS_URL=redis://localhost:6379

JWT_SECRET=change-this-min-32-chars
JWT_REFRESH_SECRET=change-this-too-min-32-chars

# Phone OTP is logged to the server console (no SMS provider configured)

# Google OAuth (get from Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Email SMTP (for email verification OTPs)
# Works with any SMTP provider: Gmail, SendGrid, AWS SES, Resend, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
EMAIL_DEV_MODE=true

# Magic Link — frontend callback URLs per role.
# The frontend sends its own window.location.origin/auth/callback at runtime (takes precedence).
# These env vars are the server-side fallback for deployments without a frontend origin.
SHIPPER_MAGIC_LINK_URL=http://localhost:3000/auth/callback
DRIVER_MAGIC_LINK_URL=http://localhost:3002/auth/callback
